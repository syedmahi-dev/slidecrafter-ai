# Gemini API Key — get yours free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Default engine: js (pptxgenjs) or python (python-pptx)
DEFAULT_ENGINE=js

# Default number of slides
DEFAULT_SLIDE_COUNT=8

# Output directory for generated .pptx files
OUTPUT_DIR=./output
